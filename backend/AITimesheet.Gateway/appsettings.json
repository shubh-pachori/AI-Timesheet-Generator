{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "api/auth/{**catch-all}"
        }
      },
      "timesheet-route": {
        "ClusterId": "timesheet-cluster",
        "Match": {
          "Path": "api/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5081/"
          }
        }
      },
      "timesheet-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5082/"
          }
        }
      }
    }
  }
}
